<% layout("/layouts/boilerplate") %>
<div class="row">
    <div class="col-8 offset-2">
        <br> <br>
    <h3>Create New Listing</h3>
   <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
    <div class="mb-3">
    <label for=" title" class="form-label">Title</label>
    <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required/>

    <div class="valid-feedback"> Title looks good</div>
    </div>
    <div  class="mb-3">
         <label for=" description" class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control " required></textarea>
    </div>

  
    <div class="row">


<div class="row">
       <div  class="mb-3 col-md-4">
<label for="price" class="form-label">Upload Image</label>
<input name="image"  placeholder="Enter URL" type="file" class="form-control" required>



    </div>

      <div  class="mb-3">
<label for="image" class="form-label">Price</label>
<input name="listing[price]"  placeholder="Enter Price" type="number" class="form-control">

    </div>



       <div  class="mb-3 col-md-8 ">
<label for="country" class="form-label">country</label>
<input name="listing[country]"  placeholder="Enter country" type="text" class="form-control" required>
<div class="invalid-feedback"> enter valid country name</div>

    </div>
</div>

       <div  class="mb-3">
<label for="location" class="form-label">Location</label>
<input name="listing[location]"  placeholder="Enter location" type="text" class="form-control" required>
<div class="invalid-feedback"> enter valid location</div>
 </div>
<br> <br>
<button class="btn btn-dark add-btn mt-3">ADD</button>
<br><br>
   </form> 
</div>
</div>
<script src ="/js/index.js"></script>